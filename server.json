{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.md-riaz/google-seo-mcp",
  "description": "MCP server for GSC, Bing, and GA4. Includes analytics, health checks, and SEO insights.",
  "repository": {
    "url": "https://github.com/md-riaz/google-seo-mcp",
    "source": "github"
  },
  "version": "1.13.5",
  "packages": [
    {
      "registryType": "npm",
      "identifier": "google-seo-mcp",
      "version": "1.13.5",
      "transport": {
        "type": "stdio"
      },
      "environmentVariables": [
        {
          "description": "Google Cloud Service Account JSON key content or path",
          "isRequired": true,
          "format": "string",
          "isSecret": true,
          "name": "GOOGLE_APPLICATION_CREDENTIALS"
        },
        {
          "description": "Bing API Key",
          "isRequired": false,
          "format": "string",
          "isSecret": true,
          "name": "BING_API_KEY"
        }
      ]
    }
  ]
}